# ─────────────────────────────────────────────
# Schedulo — Environment Variables Template
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB — Get a free cluster at mongodb.com/atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/schedulo?retryWrites=true&w=majority

# NextAuth — Generate secret: openssl rand -base64 32
AUTH_SECRET=your_nextauth_secret_here

# Google OAuth + Calendar API
# 1. Go to console.cloud.google.com
# 2. Create a project → Enable "Google Calendar API"
# 3. OAuth 2.0 Credentials → Web application
# 4. Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Gemini AI — Free at aistudio.google.com (no credit card required)
GEMINI_API_KEY=your_gemini_api_key_here

# Email (Nodemailer) — Use Gmail App Password (free)
# Generate at: myaccount.google.com/apppasswords
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-email@gmail.com
EMAIL_SERVER_PASSWORD=your_app_password_16_chars
EMAIL_FROM=Schedulo <your-email@gmail.com>
